{
  "name": "wordpicmemo",
  "version": "0.1.0",
  "private": true,
  "description": "WordPicMemo (单词图忆) - AI-powered vocabulary memorization app",
  "scripts": {
    "dev:backend": "pnpm --filter @wordpicmemo/backend run start:dev",
    "dev:mobile": "pnpm --filter @wordpicmemo/mobile run start",
    "build:shared": "pnpm --filter @wordpicmemo/shared run build",
    "build:backend": "pnpm --filter @wordpicmemo/backend run build",
    "lint": "eslint 'packages/*/src/**/*.{ts,tsx}' --fix",
    "format": "prettier --write 'packages/*/src/**/*.{ts,tsx,json}'",
    "clean": "pnpm -r exec rm -rf dist node_modules"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "bcrypt",
      "msgpackr-extract"
    ],
    "overrides": {
      "@react-native-community/cli-server-api": "15.1.3"
    }
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
